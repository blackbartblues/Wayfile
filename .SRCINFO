pkgbase = heimdall-git
	pkgdesc = A lightweight Qt6/QML file manager for Hyprland
	pkgver = r447.g78a2fec
	pkgrel = 1
	url = https://github.com/blackbartblues/Heimdall
	arch = x86_64
	arch = aarch64
	license = MIT
	makedepends = cmake
	makedepends = ninja
	makedepends = git
	makedepends = kwindowsystem
	makedepends = qt6-base
	makedepends = qt6-declarative
	makedepends = qt6-svg
	depends = glib2
	depends = kwindowsystem
	depends = qt6-base
	depends = qt6-declarative
	depends = qt6-svg
	depends = qt6-wayland
	depends = fd
	depends = xdg-utils
	optdepends = wl-clipboard: clipboard support via wl-copy and wl-paste
	optdepends = bat: syntax-highlighted text previews
	optdepends = gvfs: remote filesystem support via gio/gvfs (sftp, ftp, dav, etc.)
	optdepends = gvfs-smb: SMB/CIFS remote browsing support
	optdepends = ffmpeg: video thumbnails and audio/video metadata (via ffprobe)
	optdepends = poppler: PDF thumbnails, previews, and metadata (via pdftoppm/pdfinfo)
	optdepends = perl-image-exiftool: EXIF metadata for images (via exiftool)
	optdepends = udisks2: mount/unmount devices from sidebar
	provides = heimdall
	conflicts = heimdall
