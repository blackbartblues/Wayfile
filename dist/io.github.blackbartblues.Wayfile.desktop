[Desktop Entry]
Name=Wayfile
GenericName=File Manager
Comment=A lightweight Qt6/QML file manager for Wayland
Exec=wayfile %F
Icon=io.github.blackbartblues.Wayfile
Terminal=false
Type=Application
Categories=System;FileManager;Qt;
MimeType=inode/directory;
StartupNotify=true
StartupWMClass=io.github.blackbartblues.Wayfile
Keywords=files;explorer;manager;browser;filesystem;
