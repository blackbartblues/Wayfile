[Desktop Entry]
Name=Heimdall
GenericName=File Manager
Comment=A lightweight Qt6/QML file manager for Hyprland
Exec=heimdall %F
Icon=io.github.blackbartblues.Heimdall
Terminal=false
Type=Application
Categories=System;FileManager;Qt;
MimeType=inode/directory;
StartupNotify=true
StartupWMClass=io.github.blackbartblues.Heimdall
Keywords=files;explorer;manager;browser;filesystem;
